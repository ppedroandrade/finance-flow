# Nomes criados pela integração Supabase + Vercel (o prefixo do projeto,
# ex. `financeflow_SUPABASE_URL`, é detectado automaticamente)
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_PUBLISHABLE_KEY=sua-chave-publicavel

# Deve ser idêntico ao único usuário criado no Supabase Auth
OWNER_EMAIL=seu-email-exato@exemplo.com

# Alternativa sem a integração:
# NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-publicavel
